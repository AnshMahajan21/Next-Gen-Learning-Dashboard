# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Your project's public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Notes ──────────────────────────────────────────────────────────────────
# • Copy this file to `.env.local` and fill in your values.
# • NEVER commit `.env.local` to version control.
# • The app renders with mock data when these vars are not set,
#   so you can develop locally without a Supabase project.
